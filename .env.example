# =============================================================================
# FixIt Marketplace — environment template
# Copy to `.env` and fill with YOUR OWN (rotated) credentials.
# NEVER commit the real .env. NEVER paste real secrets into chats/tickets.
# =============================================================================

NODE_ENV=development
PORT=3000

# --- Supabase (Postgres + PostGIS) -------------------------------------------
# Get these from Supabase dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# service_role bypasses RLS — backend-only, never ship to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres connection string (Settings → Database)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- PayPal (SANDBOX FIRST — do not use Live until escrow is verified) --------
# https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_ENV=sandbox            # sandbox | live
PAYPAL_CLIENT_ID=your-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-sandbox-secret
# Webhook id from PayPal app config (for verifying webhook signatures)
PAYPAL_WEBHOOK_ID=your-webhook-id

# --- Google OAuth -------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Auth / JWT ---------------------------------------------------------------
# App session signing secret (generate your own, e.g. `openssl rand -hex 32`)
JWT_SECRET=generate-a-strong-random-secret

# --- AI Moderation (Tier 2 LLM) — Google AI Studio (Gemini) ------------------
# Server-side only — never expose to the client. https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-studio-api-key
MODERATION_MODEL=gemini-2.0-flash

# --- Masked-relay calling (Twilio Proxy) -------------------------------------
# Without these, masked calls run in SIMULATED mode (no real call placed).
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PROXY_SERVICE_SID=your-twilio-proxy-service-sid

# --- Realtime scaling (optional) ---------------------------------------------
# REDIS_URL=redis://localhost:6379
